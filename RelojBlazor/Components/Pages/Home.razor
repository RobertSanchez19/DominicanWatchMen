@page "/"
@rendermode InteractiveServer
@inject IRelojService RelojSvc
@inject ISiteConfigService Site
@inject ILogger<Home> Logger

<PageTitle>Dominican Watch Men — Inicio</PageTitle>

<HeroBanner
    Titulo="@Site.Config.HeroTitulo"
    Subtitulo="@Site.Config.HeroSubtitulo"
    BotonTexto="Ver Catálogo"
    BotonUrl="/catalogo"
    Destacados="destacados" />

<!-- ===== FEATURES ===== -->
<section class="features-section">
    <div class="features-header">
        <h2 class="section-title">¿Por qué elegirnos?</h2>
        <p class="section-sub">Cada reloj Dominican Watch Men es una obra de ingeniería artesanal.</p>
    </div>
    <div class="features-grid">
        <FeatureCard
            Icono="⌚"
            Titulo="Seiko Original"
            Descripcion="Usamos exclusivamente movimientos Seiko NH35, NH38 y NH34. Sin imitaciones." />
        <FeatureCard
            Icono="🔩"
            Titulo="Acero 316L"
            Descripcion="Cajas de acero quirúrgico grado 316L. Resistentes, duraderas, antialérgicas." />
        <FeatureCard
            Icono="💎"
            Titulo="Cristal Zafiro"
            Descripcion="Dureza Mohs 9. Antirreflejo ambas caras para máxima legibilidad." />
        <FeatureCard
            Icono="🛠️"
            Titulo="Ensamblado a Mano"
            Descripcion="Cada pieza ensamblada artesanalmente. Tolerancias de precisión milimétrica." />
    </div>
</section>

<!-- ===== PROCESO ===== -->
<section class="proceso-section">
    <div class="proceso-header">
        <div class="section-eyebrow">El Arte del Modding</div>
        <h2 class="section-title">El Proceso DWM</h2>
    </div>
    <div class="proceso-grid">
        <div class="proceso-step">
            <div class="proceso-num">01</div>
            <div class="proceso-divider"></div>
            <h4 class="proceso-title">Selección del Calibre</h4>
            <p class="proceso-desc">Elegimos el movimiento Seiko ideal — NH35, NH38 o NH34 — según la complicación y carácter de cada pieza.</p>
        </div>
        <div class="proceso-step">
            <div class="proceso-num">02</div>
            <div class="proceso-divider"></div>
            <h4 class="proceso-title">Componentes Quirúrgicos</h4>
            <p class="proceso-desc">Cajas 316L, cristales de zafiro AR, bezels, coronas y sellos con tolerancias de precisión milimétrica.</p>
        </div>
        <div class="proceso-step">
            <div class="proceso-num">03</div>
            <div class="proceso-divider"></div>
            <h4 class="proceso-title">Ensamblaje Artesanal</h4>
            <p class="proceso-desc">Cada pieza es montada a mano, paso a paso. Cada tornillo y junta, en su posición exacta.</p>
        </div>
        <div class="proceso-step">
            <div class="proceso-num">04</div>
            <div class="proceso-divider"></div>
            <h4 class="proceso-title">Control de Calidad</h4>
            <p class="proceso-desc">Test de hermeticidad, regulación del movimiento y revisión visual. Solo sale lo que pasa el estándar DWM.</p>
        </div>
    </div>
</section>

<!-- ===== CTA ===== -->
<section class="cta-section">
    <div class="cta-inner">
        <h2 class="cta-title">¿Listo para tu pieza única?</h2>
        <p class="cta-sub">Explora nuestra colección completa y encuentra el reloj que refleja tu estilo.</p>
        <a href="/catalogo" class="btn-primary">Explorar Colección</a>
        <a href="/marcas" class="btn-secondary">Ver Marcas</a>
    </div>
</section>

@code {
    private List<Reloj> destacados = new();

    protected override async Task OnInitializedAsync()
    {
        await Site.CargarAsync();
        try
        {
            var todos = await RelojSvc.GetAllAsync();
            destacados = todos.Where(r => r.Destacado).ToList();
            Logger.LogInformation("Home: {Count} relojes en portada", destacados.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Home: no se pudieron cargar los relojes destacados");
        }
    }
}
