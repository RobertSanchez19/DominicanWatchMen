@inject IJSRuntime JS
<div class="admin-list">
    <div class="admin-list-header">
        <h3 class="admin-list-title">Productos (@Relojes.Count())</h3>
        <button class="btn-primary admin-btn-nuevo" @onclick="NuevoReloj">+ Nuevo Reloj</button>
    </div>

    @if (!Relojes.Any())
    {
        <div class="admin-empty">No hay relojes registrados. ¡Agrega el primero!</div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Imagen</th>
                        <th>Nombre</th>
                        <th>Modelo</th>
                        <th>Marca</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Relojes)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(r.ImagenUrl))
                                {
                                    <img src="@r.ImagenUrl" alt="@r.Nombre" class="admin-thumb" />
                                }
                                else
                                {
                                    <div class="admin-thumb-empty">⌚</div>
                                }
                            </td>
                            <td class="admin-td-nombre">
                                @r.Nombre
                                @if (r.Destacado)
                                {
                                    <span class="admin-badge-portada" title="En portada">⭐ Portada</span>
                                }
                            </td>
                            <td>@r.Modelo</td>
                            <td>@(r.Marca?.Nombre ?? "-")</td>
                            <td>$@r.Precio.ToString("N0")</td>
                            <td>@r.Stock</td>
                            <td class="admin-td-actions">
                                <button class="admin-btn-edit" @onclick="() => OnEditar.InvokeAsync(r)">✏️</button>
                                <button class="admin-btn-del" @onclick="() => EliminarConConfirmacion(r)">🗑️</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    [Parameter] public IEnumerable<Reloj> Relojes { get; set; } = [];
    [Parameter] public EventCallback<Reloj> OnEditar { get; set; }
    [Parameter] public EventCallback<int> OnEliminar { get; set; }

    private void NuevoReloj() => OnEditar.InvokeAsync(new Reloj());

    private async Task EliminarConConfirmacion(Reloj r)
    {
        // Interop C# -> JS que DEVUELVE un valor: pedimos confirmacion al navegador
        // y recibimos true/false de vuelta desde JavaScript.
        var confirmado = await JS.InvokeAsync<bool>("dwm.confirmar",
            $"¿Eliminar \"{r.Nombre}\"? Esta acción no se puede deshacer.");
        if (!confirmado)
        {
            return;
        }

        await OnEliminar.InvokeAsync(r.Id);
        // Interop C# -> JS (sin retorno): avisamos al usuario.
        await JS.InvokeVoidAsync("dwm.notificar", $"Reloj \"{r.Nombre}\" eliminado correctamente.");
    }
}
